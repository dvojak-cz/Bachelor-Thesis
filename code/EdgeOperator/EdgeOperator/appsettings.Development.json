{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
        "Override": {
            "cz.dvojak": "Information"
        }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:G} {Level:u3}] {Message:lj}{NewLine:1}{Exception:1}",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
